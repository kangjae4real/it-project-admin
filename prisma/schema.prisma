generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

/// 리그 구분 (참조 테이블)
model League {
  id    Int    @id @default(autoincrement())
  name  String @unique // 리그명
  teams Team[]
}

/// 학과 (참조 테이블)
model Department {
  id      Int      @id @default(autoincrement())
  name    String   @unique // 학과명
  members Member[]
}

/// 팀
model Team {
  id        Int       @id @default(autoincrement())
  name      String // 팀명
  leagueId  Int // 소속 리그
  league    League    @relation(fields: [leagueId], references: [id], onDelete: Restrict)
  members   Member[] // 소속 팀원들
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft delete (null = 활성)

  @@index([leagueId])
}

/// 팀원
model Member {
  id         Int       @id @default(autoincrement())
  name       String // 이름
  studentId    String // 학번 (앞자리 0 가능성 → String)
  departmentId Int // 학과
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  droppedOut   Boolean    @default(false) // 중도하차 여부
  teamId       Int // 소속 팀
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Restrict)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime? // soft delete (null = 활성)

  @@index([teamId])
  @@index([departmentId])
}
